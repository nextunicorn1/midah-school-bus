---
// src/pages/track.astro
import Layout from '../layouts/Layout.astro'; 

// 1. Grab the API key securely from your .env file
const mapKey = import.meta.env.PUBLIC_MAPTILER_KEY;
---

<Layout title="Live Van Tracker | Midah School Bus">
    <main class="max-w-6xl mx-auto p-4 md:p-8">
        <h1 class="text-4xl font-extrabold text-gray-900 mb-2">
            Live <span class="text-yellow-500">Van Tracker</span>
        </h1>
        <p class="text-gray-600 mb-2">
            Watch the school van's location in real-time.
        </p>
        
        <p id="status" class="text-sm font-bold text-red-500 mb-6">
            🔴 Connecting to live server...
        </p>

        <div id="map" class="w-full h-[600px] rounded-2xl shadow-xl border border-gray-200 z-10"></div>
    </main>

    <link href="https://unpkg.com/maplibre-gl@3.x/dist/maplibre-gl.css" rel="stylesheet" />
    <script src="https://unpkg.com/maplibre-gl@3.x/dist/maplibre-gl.js" is:inline></script>

    <!-- 2. Pass the key into the script using define:vars -->
    <script is:inline define:vars={{ API_KEY: mapKey }}>
        const styleUrl = `https://api.maptiler.com/maps/streets-v2/style.json?key=${API_KEY}`;
        let currentPos = [101.73411, 3.10146]; // Default KL
        
        const map = new maplibregl.Map({
            container: 'map', 
            style: styleUrl,
            center: currentPos,
            zoom: 15,
            maxZoom: 18,
            minZoom: 10,
            touchPitch: false,
            pitchWithRotate: false,
            dragRotate: false
        });

        // ==========================================
        // NEW: Add the "Locate Me" Blue Dot
        // ==========================================
        const geolocate = new maplibregl.GeolocateControl({
            positionOptions: {
                enableHighAccuracy: true
            },
            trackUserLocation: true, // Moves the blue dot if the user is walking
            showUserHeading: true    // Shows a little arrow pointing where their phone is facing
        });
        
        map.addControl(geolocate, 'bottom-right'); // Puts the GPS button in the corner

        // ==========================================
        // ADVANCED MATH: Calculate Bearing (Rotation)
        // ==========================================
        function getBearing(start, end) {
            const startLat = start[1] * Math.PI / 180;
            const startLng = start[0] * Math.PI / 180;
            const endLat = end[1] * Math.PI / 180;
            const endLng = end[0] * Math.PI / 180;

            const dLng = endLng - startLng;
            const y = Math.sin(dLng) * Math.cos(endLat);
            const x = Math.cos(startLat) * Math.sin(endLat) - Math.sin(startLat) * Math.cos(endLat) * Math.cos(dLng);
            const bearing = Math.atan2(y, x) * 180 / Math.PI;
            return (bearing + 360) % 360;
        }

        // ==========================================
        // NEW: Professional Top-Down Van Graphic
        // ==========================================
        map.on('load', () => {
            // A pure SVG top-down yellow school van!
            const vanSvg = `
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64">
              <rect x="14" y="10" width="36" height="48" rx="8" fill="rgba(0,0,0,0.3)" />
              <rect x="16" y="8" width="32" height="48" rx="8" fill="#FACC15" />
              <rect x="20" y="16" width="24" height="6" rx="1" fill="#1E293B" />
              <rect x="22" y="48" width="20" height="4" rx="1" fill="#1E293B" />
              <rect x="18" y="8" width="6" height="3" rx="1" fill="#FEF08A" />
              <rect x="40" y="8" width="6" height="3" rx="1" fill="#FEF08A" />
              <rect x="18" y="54" width="8" height="2" rx="1" fill="#EF4444" />
              <rect x="38" y="54" width="8" height="2" rx="1" fill="#EF4444" />
            </svg>`;

            const imgUrl = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(vanSvg);

            map.loadImage(imgUrl, (error, image) => {
                if (error) throw error;
                map.addImage('bus-icon', image);

                map.addSource('van-source', {
                    type: 'geojson',
                    data: { type: 'Point', coordinates: currentPos }
                });

                map.addLayer({
                    id: 'van-layer',
                    type: 'symbol',
                    source: 'van-source',
                    layout: {
                        'icon-image': 'bus-icon',
                        'icon-size': 0.8, 
                        'icon-pitch-alignment': 'map',    // Glues it flat to the map
                        'icon-rotation-alignment': 'map', // Rotates correctly on the ground
                        'icon-allow-overlap': true
                    }
                });

                loadInitialLocation();
            });
        });

        // ==========================================
        // UPGRADED: Conflict-Free Animation
        // ==========================================
        let animationId = null;
        let actualDisplayPos = currentPos; // Tracks exactly where the bus is mid-glide

        function animateVan(startPos, endPos, durationMs) {
            // 1. KILL the old animation if a new ping arrives early! (Fixes jitter)
            if (animationId) cancelAnimationFrame(animationId);

            // 2. Calculate the direction the van is heading
            const targetBearing = getBearing(startPos, endPos);
            
            // 3. Rotate the bus icon to face the road (The "Grab" effect)
            if (map.getLayer('van-layer')) {
                map.setLayoutProperty('van-layer', 'icon-rotate', targetBearing);
            }

            let startTimestamp = null;
            
            function step(timestamp) {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / durationMs, 1);
                
                // Calculate the exact pixel point
                const currentLng = startPos[0] + (endPos[0] - startPos[0]) * progress;
                const currentLat = startPos[1] + (endPos[1] - startPos[1]) * progress;
                
                actualDisplayPos = [currentLng, currentLat]; 
                
                // Update the map
                map.getSource('van-source').setData({
                    type: 'Point',
                    coordinates: actualDisplayPos
                });
                
                if (progress < 1) {
                    animationId = requestAnimationFrame(step);
                }
            }
            animationId = requestAnimationFrame(step);
        }

        async function loadInitialLocation() {
            try {
                const res = await fetch('https://api.midahschoolbus.my/api/vehicles/locations');
                if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
                const data = await res.json();
                
                if (data && data.length > 0) {
                    const vanData = data[0];
                    currentPos = [vanData[1], vanData[2]]; 
                    actualDisplayPos = currentPos; // <-- ADD THIS LINE!
                    
                    map.getSource('van-source').setData({ type: 'Point', coordinates: currentPos });
                    map.jumpTo({ center: currentPos, zoom: 16 }); 
                }
            } catch (err) {
                console.error("Fetch error:", err);
            }
        }
        
        // ==========================================
        // 5. NATIVE SSE LIVE STREAM (No Socket.io!)
        // ==========================================
        let isFirstPing = true;
        const statusText = document.getElementById('status'); 
        
        // Open the native browser EventSource connection
        const eventSource = new EventSource('https://api.midahschoolbus.my/api/vehicles/stream');

        eventSource.onopen = () => {
            if (statusText) {
                statusText.textContent = "🟢 Live Connected";
                statusText.className = "text-sm font-bold text-green-500 mb-6";
            }
        };

        // If connection drops, EventSource will automatically try to reconnect!
        eventSource.onerror = () => {
            if (statusText) {
                statusText.textContent = "🔴 Connection Lost. Reconnecting...";
                statusText.className = "text-sm font-bold text-red-500 mb-6";
            }
        };

        // ==========================================
        // UPGRADED: SSE Listener
        // ==========================================
        let lastPingTime = performance.now();

        eventSource.onmessage = (event) => {
            const vanData = JSON.parse(event.data);
            const newPos = [vanData[1], vanData[2]]; 
            
            const now = performance.now();
            let dynamicDuration = now - lastPingTime;
            lastPingTime = now;

            // Cap the network delay between 2 and 4 seconds
            dynamicDuration = Math.max(2000, Math.min(dynamicDuration, 4000));
            
            // CRITICAL: Start the new glide from exactly where the bus is *right now*, 
            // not where it was supposed to be. Fixes teleporting.
            const startPosToUse = actualDisplayPos || currentPos;
            
            animateVan(startPosToUse, newPos, dynamicDuration); 
            currentPos = newPos; 
            
            if (isFirstPing) {
                map.flyTo({ center: newPos, zoom: 16 });
                isFirstPing = false;
            }
        };
    </script>
</Layout>