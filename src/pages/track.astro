---
// src/pages/track.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Live Van Tracker">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>

<style is:inline>
    .leaflet-marker-icon {
      /* 1 second, linear (constant speed, no slowing down at the end) */
      transition: transform 1s linear !important; 
      /* Tells the GPU to optimize this specific element for movement */
      will-change: transform; 
    }
  </style>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-3xl font-extrabold text-gray-900">Live <span class="text-yellow-500">Van Tracker</span></h1>
      <p class="text-gray-600">Watch the school van's location in real-time (Powered by OpenStreetMap & WebSockets).</p>
      <p id="status" class="text-sm font-bold text-red-500 mt-2">🔴 Connecting to live server...</p>
    </div>

    <div class="w-full h-[70vh] rounded-2xl overflow-hidden shadow-lg border border-gray-200 z-0 relative">
      <div id="map" class="w-full h-full bg-gray-100"></div>
    </div>
  </div>

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  
  <script is:inline src="https://cdn.socket.io/4.7.4/socket.io.min.js" crossorigin=""></script>

<script is:inline>
    // 1. Map Setup
    const initialPos = [3.10146, 101.73411]; 
    const map = L.map('map').setView(initialPos, 15);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '© OpenStreetMap'
    }).addTo(map);

    const vanIcon = L.divIcon({
      html: '<div style="font-size: 32px; line-height: 1;">🚌</div>',
      className: 'transparent-icon',
      iconSize: [32, 32],
      iconAnchor: [16, 16],
      popupAnchor: [0, -16]
    });

    const marker = L.marker(initialPos, { icon: vanIcon }).addTo(map);

    // 2. Fetch Last Known Location
    async function loadInitialLocation() {
      try {
        const res = await fetch('https://api.midahschoolbus.my/api/vehicles/locations');
        const data = await res.json();
        
        if (data && data.length > 0) {
          const van = data[0];
          const startPos = [van.latitude, van.longitude];
          marker.setLatLng(startPos);
          map.setView(startPos, 16); 
        }
      } catch (err) {
        console.error("Fetch error:", err);
      }
    }
    
    loadInitialLocation();

    // 3. Live Socket Connection
    const statusText = document.getElementById('status'); 
    const socket = io('https://api.midahschoolbus.my');

    // Turn text green on successful connection
    socket.on('connect', () => {
      statusText.textContent = "🟢 Live Connected";
      statusText.className = "text-sm font-bold text-green-500 mt-2";
      console.log("Connected to WebSocket!");
    });

    // Handle disconnects
    socket.on('disconnect', () => {
      statusText.textContent = "🔴 Connection Lost. Reconnecting...";
      statusText.className = "text-sm font-bold text-red-500 mt-2";
    });

    // Move the bus when hardware pings
    socket.on('vanLocationUpdate', (van) => {
      const newPos = [van.latitude, van.longitude];
      marker.setLatLng(newPos);
    });
</script>
</Layout>