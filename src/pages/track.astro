---
// src/pages/track.astro
import Layout from '../layouts/Layout.astro';

// Pull the public API key from your .env file
const apiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
---

<Layout title="Live Van Tracker">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-3xl font-extrabold text-gray-900">Live <span class="text-yellow-500">Van Tracker</span></h1>
      <p class="text-gray-600">Watch the school van's location in real-time.</p>
    </div>

    <div class="w-full h-[70vh] rounded-2xl overflow-hidden shadow-lg border border-gray-200">
      <div id="map" class="w-full h-full bg-gray-100"></div>
    </div>
  </div>

  <script define:vars={{ apiKey }}>
    let map;
    let marker;
    let infoWindow;

    async function initMap() {
      // Default center (Kuala Lumpur)
      const initialPos = { lat: 3.10146, lng: 101.73411 };

      map = new google.maps.Map(document.getElementById("map"), {
        zoom: 15,
        center: initialPos,
        disableDefaultUI: true, 
        zoomControl: true,
      });

      marker = new google.maps.Marker({
        position: initialPos,
        map: map,
        title: "School Van",
      });

      infoWindow = new google.maps.InfoWindow();

      // Fetch immediately, then loop every 10 seconds
      await fetchLocation();
      setInterval(fetchLocation, 10000);
    }

    async function fetchLocation() {
      try {
        // Fetch securely from your Astro middleman route!
        const response = await fetch('/api/van');
        const data = await response.json();

        if (data && data.length > 0) {
          const van = data[0]; 
          const pos = { lat: van.latitude, lng: van.longitude };

          marker.setPosition(pos);
          map.panTo(pos);

          const timeString = new Date(van.timestamp).toLocaleTimeString('en-MY');
          infoWindow.setContent(`
            <div style="color: black; font-family: sans-serif; padding: 4px;">
              <strong style="font-size: 1.1em;">School Van</strong><br>
              Speed: <span style="color: ${van.speed_kmh > 0 ? 'green' : 'gray'}">${van.speed_kmh} km/h</span><br>
              Updated: ${timeString}
            </div>
          `);
          
          infoWindow.open({
            anchor: marker,
            map,
            shouldFocus: false,
          });
        }
      } catch (error) {
        console.error("Error fetching van location:", error);
      }
    }

    window.initMap = initMap;
  </script>

  <script async defer src={`https://maps.googleapis.com/maps/api/js?key=${apiKey}&callback=initMap`}></script>
</Layout>