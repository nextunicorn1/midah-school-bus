---
// src/pages/track.astro
import Layout from '../layouts/Layout.astro'; 

// 1. Grab the API key securely from your .env file
const mapKey = import.meta.env.PUBLIC_MAPTILER_KEY;
---

<Layout title="Live Van Tracker | Midah School Bus">
    <main class="max-w-6xl mx-auto p-4 md:p-8">
        <h1 class="text-4xl font-extrabold text-gray-900 mb-2">
            Live <span class="text-yellow-500">Van Tracker</span>
        </h1>
        <p class="text-gray-600 mb-2">
            Watch the school van's location in real-time (Powered by Vector Tiles & WebSockets).
        </p>
        
        <p id="status" class="text-sm font-bold text-red-500 mb-6">
            🔴 Connecting to live server...
        </p>

        <div id="map" class="w-full h-[600px] rounded-2xl shadow-xl border border-gray-200 z-10"></div>
    </main>

    <link href="https://unpkg.com/maplibre-gl@3.x/dist/maplibre-gl.css" rel="stylesheet" />
    <script src="https://unpkg.com/maplibre-gl@3.x/dist/maplibre-gl.js" is:inline></script>
    <script src="https://cdn.socket.io/4.7.4/socket.io.min.js" is:inline></script>

    <!-- 2. Pass the key into the script using define:vars -->
    <script is:inline define:vars={{ API_KEY: mapKey }}>
        const styleUrl = `https://api.maptiler.com/maps/streets-v2/style.json?key=${API_KEY}`;
        let currentPos = [101.73411, 3.10146]; // Default KL
        
        const map = new maplibregl.Map({
            container: 'map', 
            style: styleUrl,
            center: currentPos,
            zoom: 15,
            pitch: 45, 
        });

        // ==========================================
        // NEW: Draw Emoji inside WebGL for 3D integration
        // ==========================================
        function createBusIcon() {
            const size = 64;
            const canvas = document.createElement('canvas');
            canvas.width = size; canvas.height = size;
            const ctx = canvas.getContext('2d');
            ctx.font = '40px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('🚌', size/2, size/2);
            return ctx.getImageData(0, 0, size, size);
        }

        // ==========================================
        // NEW: Professional Canvas Map Pin (The "Grab" Look)
        // ==========================================
        function createBusPin() {
            const size = 80;
            const canvas = document.createElement('canvas');
            canvas.width = size; canvas.height = size;
            const ctx = canvas.getContext('2d');

            // 1. Draw thick white border (shadow/outline effect)
            ctx.beginPath();
            ctx.arc(size/2, size/2, 34, 0, Math.PI * 2);
            ctx.fillStyle = '#FFFFFF';
            ctx.fill();

            // 2. Draw the yellow Grab-style circle
            ctx.beginPath();
            ctx.arc(size/2, size/2, 28, 0, Math.PI * 2);
            ctx.fillStyle = '#EAB308'; // Bold Yellow
            ctx.fill();

            // 3. Draw the Bus Emoji perfectly centered inside
            ctx.font = '32px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('🚌', size/2, size/2 + 2); 

            // Return the raw pixel data to MapLibre
            return ctx.getImageData(0, 0, size, size);
        }

        map.on('load', () => {
            // Load the generated canvas image into the map
            map.addImage('bus-icon', createBusPin());

            map.addSource('van-source', {
                type: 'geojson',
                data: { type: 'Point', coordinates: currentPos }
            });

            map.addLayer({
                id: 'van-layer',
                type: 'symbol',
                source: 'van-source',
                layout: {
                    'icon-image': 'bus-icon',
                    'icon-size': 0.8, // Adjust this to make the whole pin bigger or smaller
                    'icon-pitch-alignment': 'viewport', // Stands upright facing the user!
                    'icon-rotation-alignment': 'viewport',
                    'icon-allow-overlap': true
                }
            });

            loadInitialLocation();
        });

        // ==========================================
        // NEW: JavaScript Math Glide (Fixes panning bug)
        // ==========================================
        function animateVan(startPos, endPos, durationMs) {
            let startTimestamp = null;
            
            function step(timestamp) {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / durationMs, 1);
                
                // Calculate the exact point between A and B
                const currentLng = startPos[0] + (endPos[0] - startPos[0]) * progress;
                const currentLat = startPos[1] + (endPos[1] - startPos[1]) * progress;
                
                // Update the native map source
                map.getSource('van-source').setData({
                    type: 'Point',
                    coordinates: [currentLng, currentLat]
                });
                
                if (progress < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
        }

        async function loadInitialLocation() {
            try {
                const res = await fetch('https://api.midahschoolbus.my/api/vehicles/locations');
                if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
                const data = await res.json();
                
                if (data && data.length > 0) {
                    const van = data[0];
                    currentPos = [van.longitude, van.latitude];
                    
                    // Instantly snap to saved location
                    map.getSource('van-source').setData({ type: 'Point', coordinates: currentPos });
                    map.jumpTo({ center: currentPos, zoom: 16 }); 
                }
            } catch (err) {
                console.error("Fetch error:", err);
            }
        }
        
        let isFirstPing = true;
        const statusText = document.getElementById('status'); 
        const socket = io('https://api.midahschoolbus.my');

        socket.on('connect', () => {
            if (statusText) {
                statusText.textContent = "🟢 Live Connected";
                statusText.className = "text-sm font-bold text-green-500 mb-6";
            }
        });

        socket.on('disconnect', () => {
            if (statusText) {
                statusText.textContent = "🔴 Connection Lost. Reconnecting...";
                statusText.className = "text-sm font-bold text-red-500 mb-6";
            }
        });

        socket.on('vanLocationUpdate', (van) => {
            const newPos = [van.longitude, van.latitude]; 
            
            // Glide smoothly to the new ping over 1 second (1000ms)
            animateVan(currentPos, newPos, 1000); 
            currentPos = newPos; // Update our tracking variable
            
            if (isFirstPing) {
                map.flyTo({ center: newPos, zoom: 16 });
                isFirstPing = false;
            }
        });
    </script>
</Layout>