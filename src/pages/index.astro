---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home">
  <div class="text-center py-20 px-4">
    <div class="inline-block bg-yellow-100 text-yellow-800 px-4 py-1 rounded-full text-sm font-bold mb-6">
      Now Registering for 2026
    </div>
    <h1 class="text-5xl md:text-6xl font-extrabold mb-6 tracking-tight text-gray-900">
      Safe. Reliable. <span class="text-yellow-500">On Time.</span>
    </h1>
    <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
      Professional school bus services for students in Cheras, Bandar Tun Razak, and surrounding areas. Trackable, secure, and managed by real people.
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/register" class="bg-yellow-400 text-black font-bold py-4 px-8 rounded-xl shadow-lg hover:bg-yellow-300 hover:-translate-y-1 transition transform">
        Secure a Seat ➜
      </a>
      <a href="/routes" class="bg-white border border-gray-200 text-gray-700 font-bold py-4 px-8 rounded-xl hover:bg-gray-50 transition">
        Check Coverage Areas
      </a>
    </div>
  </div>
</Layout>