---
// src/pages/manifest.astro
import Layout from '../layouts/Layout.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'https://api.midahschoolbus.my';
const TENANT_ID = 1;
---

<Layout title="Daily Manifest | Midah School Bus">
    <main class="max-w-6xl mx-auto p-4 md:p-8">

        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-extrabold text-gray-900 mb-2">
                Daily <span class="text-yellow-500">Manifest</span>
            </h1>
            <p class="text-gray-600">Generate and manage the morning and afternoon student lists.</p>
        </div>

        <!-- Controls bar -->
        <div class="bg-white rounded-2xl shadow border border-gray-200 p-4 mb-4 flex flex-wrap gap-3 items-end">
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Date</label>
                <input
                    type="date"
                    id="manifest-date"
                    class="border border-gray-300 rounded-lg px-3 py-2 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-yellow-400"
                />
            </div>
            <button
                id="btn-generate"
                class="bg-yellow-400 hover:bg-yellow-300 text-black font-bold py-2 px-6 rounded-xl shadow transition hover:-translate-y-0.5 transform text-sm"
            >
                ⚡ Generate Manifest
            </button>
            <button
                id="btn-load"
                class="bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 font-bold py-2 px-6 rounded-xl shadow-sm transition text-sm"
            >
                🔄 Load Existing
            </button>
            <span id="manifest-status" class="text-sm text-gray-400 ml-auto self-center"></span>
        </div>

        <!-- Filter / Sort bar -->
        <div class="bg-white rounded-2xl shadow border border-gray-200 p-4 mb-6 flex flex-wrap gap-3 items-end">
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">School</label>
                <select id="filter-school" class="border border-gray-300 rounded-lg px-3 py-2 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-yellow-400 min-w-[160px]">
                    <option value="">All Schools</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Van / Route</label>
                <select id="filter-van" class="border border-gray-300 rounded-lg px-3 py-2 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-yellow-400 min-w-[140px]">
                    <option value="">All Vans</option>
                    <option value="PMW2268">PMW2268</option>
                    <option value="WA6935C">WA6935C</option>
                    <option value="VL1709">VL1709</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Sort by End Time</label>
                <select id="sort-time" class="border border-gray-300 rounded-lg px-3 py-2 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-yellow-400">
                    <option value="">Default</option>
                    <option value="asc">Earliest First</option>
                    <option value="desc">Latest First</option>
                </select>
            </div>
            <button
                id="btn-apply-filters"
                class="bg-gray-800 hover:bg-gray-700 text-white font-bold py-2 px-5 rounded-xl shadow-sm transition text-sm"
            >
                Apply
            </button>
            <button
                id="btn-clear-filters"
                class="bg-white border border-gray-300 hover:bg-gray-50 text-gray-500 font-bold py-2 px-4 rounded-xl shadow-sm transition text-sm"
            >
                Clear
            </button>
        </div>

        <!-- Morning Section -->
        <section class="mb-10">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                <h2 class="text-2xl font-extrabold text-gray-900">🌅 Morning Manifest</h2>
                <span id="morning-count" class="bg-yellow-100 text-yellow-800 text-xs font-bold px-2 py-0.5 rounded-full"></span>
            </div>
            <div id="morning-manifest" class="space-y-2">
                <div class="text-gray-400 text-sm italic">No manifest loaded yet. Select a date and click Generate.</div>
            </div>
        </section>

        <!-- Afternoon Section -->
        <section class="mb-10">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-3 h-3 rounded-full bg-orange-400"></div>
                <h2 class="text-2xl font-extrabold text-gray-900">🌇 Afternoon Manifest</h2>
                <span id="afternoon-count" class="bg-orange-100 text-orange-800 text-xs font-bold px-2 py-0.5 rounded-full"></span>
            </div>
            <div id="afternoon-manifest" class="space-y-2">
                <div class="text-gray-400 text-sm italic">No manifest loaded yet. Select a date and click Generate.</div>
            </div>
        </section>

    </main>

    <!-- Absence reason modal -->
    <div id="absence-modal" class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 hidden">
        <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4">
            <h3 class="text-lg font-extrabold mb-1">Mark as Absent</h3>
            <p id="modal-student-name" class="text-gray-500 text-sm mb-4"></p>
            <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Reason (optional)</label>
            <input
                id="absence-reason"
                type="text"
                placeholder="e.g. Sick, family trip…"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-yellow-400"
            />
            <div class="flex gap-2">
                <button id="modal-confirm" class="flex-1 bg-red-500 hover:bg-red-400 text-white font-bold py-2 rounded-xl text-sm transition">
                    Confirm Absent
                </button>
                <button id="modal-cancel" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2 rounded-xl text-sm transition">
                    Cancel
                </button>
            </div>
        </div>
    </div>

    <script is:inline define:vars={{ API_BASE, TENANT_ID }}>

        // ==========================================
        // State
        // ==========================================

        // Raw data cache: { morning: [], afternoon: [] }
        let _manifestData = { morning: [], afternoon: [] };
        // Transfer maps: { morning: Map<studentId, transferInfo>, afternoon: Map<...> }
        let _transferData = { morning: new Map(), afternoon: new Map() };

        // ==========================================
        // Helpers
        // ==========================================
        function today() {
            return new Date().toISOString().split('T')[0];
        }

        function formatTime(timeStr) {
            if (!timeStr) return '—';
            const [h, m] = timeStr.split(':');
            const hour = parseInt(h);
            const ampm = hour >= 12 ? 'PM' : 'AM';
            return ((hour % 12) || 12) + ':' + m + ' ' + ampm;
        }

        // Parse "HH:MM:SS" or "HH:MM" to total minutes for sorting
        function timeToMinutes(timeStr) {
            if (!timeStr) return Infinity;
            const parts = timeStr.split(':');
            return parseInt(parts[0]) * 60 + parseInt(parts[1]);
        }

        function statusBadge(row) {
            if (row.is_absent) {
                return `<span class="inline-block bg-red-100 text-red-700 text-xs font-bold px-2 py-0.5 rounded-full">Absent</span>`;
            }
            const map = {
                scheduled:  'bg-gray-100 text-gray-600',
                boarded:    'bg-green-100 text-green-700',
                completed:  'bg-blue-100 text-blue-700',
                no_show:    'bg-orange-100 text-orange-700',
            };
            const cls = map[row.status] ?? 'bg-gray-100 text-gray-500';
            const label = row.status.charAt(0).toUpperCase() + row.status.slice(1).replace('_', ' ');
            return `<span class="inline-block ${cls} text-xs font-bold px-2 py-0.5 rounded-full">${label}</span>`;
        }

        // ==========================================
        // Transfer badge
        // ==========================================
        function transferBadge(tripType, studentId) {
            const info = _transferData[tripType].get(studentId);
            if (!info) return '';
            const point = info.transfer_point_name ?? '?';
            const plate = info.outbound_van_plate ?? '?';
            return `<span class="inline-flex items-center gap-1 bg-purple-100 text-purple-700 text-xs font-bold px-2 py-0.5 rounded-full" title="Transfer: ${point} → ${plate}">
                🔀 ${point} · ${plate}
            </span>`;
        }

        // ==========================================
        // Inline end-time editor
        // ==========================================
        function endTimeDisplay(row) {
            const timeVal = row.scheduled_end_time ? row.scheduled_end_time.slice(0, 5) : ''; // "HH:MM"
            const display = formatTime(row.scheduled_end_time);
            return `<span
                class="end-time-display cursor-pointer hover:underline hover:text-yellow-600 transition text-sm font-medium"
                data-row-id="${row.id}"
                data-current="${timeVal}"
                title="Click to edit end time"
                onclick="openEndTimeEditor(this)"
            >${display}</span>`;
        }

        window.openEndTimeEditor = function(spanEl) {
            // Prevent double-open
            if (spanEl.parentElement.querySelector('input[type="time"]')) return;

            const rowId = spanEl.dataset.rowId;
            const current = spanEl.dataset.current; // "HH:MM"

            const input = document.createElement('input');
            input.type = 'time';
            input.value = current;
            input.className = 'border border-yellow-400 rounded px-1 py-0.5 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-yellow-400 w-28';

            const saveBtn = document.createElement('button');
            saveBtn.textContent = '✓';
            saveBtn.className = 'text-xs bg-yellow-400 hover:bg-yellow-300 text-black font-bold px-2 py-0.5 rounded transition ml-1';

            const cancelBtn = document.createElement('button');
            cancelBtn.textContent = '✕';
            cancelBtn.className = 'text-xs bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold px-2 py-0.5 rounded transition ml-1';

            // Hide the span and insert controls after it
            spanEl.classList.add('hidden');
            spanEl.after(cancelBtn);
            spanEl.after(saveBtn);
            spanEl.after(input);

            function cleanup() {
                input.remove();
                saveBtn.remove();
                cancelBtn.remove();
                spanEl.classList.remove('hidden');
            }

            cancelBtn.addEventListener('click', cleanup);

            saveBtn.addEventListener('click', async () => {
                const newTime = input.value; // "HH:MM"
                if (!newTime) { cleanup(); return; }
                saveBtn.textContent = '…';
                saveBtn.disabled = true;
                try {
                    await apiFetch(`/${rowId}/end-time`, {
                        method: 'PATCH',
                        body: JSON.stringify({ scheduled_end_time: newTime }),
                    });
                    // Update cached data
                    for (const type of ['morning', 'afternoon']) {
                        const r = _manifestData[type].find(r => r.id == rowId);
                        if (r) r.scheduled_end_time = newTime + ':00';
                    }
                    spanEl.dataset.current = newTime;
                    spanEl.textContent = formatTime(newTime + ':00');
                    cleanup();
                } catch (err) {
                    alert('Failed to save end time: ' + err.message);
                    saveBtn.textContent = '✓';
                    saveBtn.disabled = false;
                }
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') saveBtn.click();
                if (e.key === 'Escape') cleanup();
            });

            input.focus();
        };

        // ==========================================
        // Row renderer
        // ==========================================
        function renderRow(row, tripType) {
            const isAbsent = row.is_absent;
            const rowBg = isAbsent ? 'bg-red-50 border-red-200' : 'bg-white border-gray-200';

            // Feature 5: stop names instead of coordinates
            const stopLabel = tripType === 'morning'
                ? `<span class="text-gray-400 text-xs">📍 Pickup:</span> <span class="text-sm font-medium">${row.pickup_stop_name ?? '—'}</span>`
                : `<span class="text-gray-400 text-xs">📍 Dropoff:</span> <span class="text-sm font-medium">${row.dropoff_stop_name ?? '—'}</span>`;

            // Feature 4: inline end-time editor (afternoon only; morning has no meaningful end time)
            const endTimeHtml = tripType === 'afternoon'
                ? `<span class="text-gray-400 text-xs ml-3">🕐 End:</span> ${endTimeDisplay(row)}`
                : '';

            const notes = row.driver_notes
                ? `<div class="mt-1 text-xs text-amber-700 bg-amber-50 rounded px-2 py-0.5 inline-block">📝 ${row.driver_notes}</div>`
                : '';

            const medical = row.medical_notes
                ? `<div class="mt-1 text-xs text-red-700 bg-red-50 rounded px-2 py-0.5 inline-block">🏥 ${row.medical_notes}</div>`
                : '';

            const absentReason = isAbsent && row.absence_reason
                ? `<div class="text-xs text-red-500 mt-0.5">Reason: ${row.absence_reason}</div>`
                : '';

            // Feature 6: transfer badge
            const transfer = transferBadge(tripType, row.student_id ?? row.id);

            const absentBtn = isAbsent
                ? `<button
                        onclick="markPresent(${row.id}, this)"
                        class="text-xs bg-green-100 hover:bg-green-200 text-green-700 font-bold px-3 py-1 rounded-lg transition"
                    >✓ Mark Present</button>`
                : `<button
                        onclick="openAbsenceModal(${row.id}, '${row.student_name.replace(/'/g, "\\'")}', this)"
                        class="text-xs bg-red-100 hover:bg-red-200 text-red-700 font-bold px-3 py-1 rounded-lg transition"
                    >✕ Mark Absent</button>`;

            return `
                <div id="row-${row.id}" class="rounded-xl border ${rowBg} px-4 py-3 flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 transition">
                    <!-- Sequence number -->
                    <div class="text-2xl font-extrabold text-gray-200 w-8 shrink-0 text-center">${row.sequence_order ?? '—'}</div>

                    <!-- Main info -->
                    <div class="flex-1 min-w-0">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="font-bold text-gray-900">${row.student_name}</span>
                            ${statusBadge(row)}
                            ${row.grade_level ? `<span class="text-xs text-gray-400">${row.grade_level}</span>` : ''}
                            ${transfer}
                        </div>
                        <div class="mt-0.5">
                            ${stopLabel}
                            ${endTimeHtml}
                        </div>
                        <div class="mt-0.5">
                            <span class="text-gray-400 text-xs">🏫</span> <span class="text-sm text-gray-600">${row.school_name ?? '—'}</span>
                            <span class="text-gray-300 mx-1">·</span>
                            <span class="text-gray-400 text-xs">🚌</span> <span class="text-sm text-gray-600">${row.route_name ?? '—'} (${row.vehicle_plate ?? '—'})</span>
                        </div>
                        ${notes}${medical}${absentReason}
                    </div>

                    <!-- Actions -->
                    <div class="shrink-0">
                        ${absentBtn}
                    </div>
                </div>
            `;
        }

        // ==========================================
        // Filter + sort helpers
        // ==========================================
        function getFilters() {
            return {
                school: document.getElementById('filter-school').value,
                van:    document.getElementById('filter-van').value,
                sort:   document.getElementById('sort-time').value,
            };
        }

        function applyFiltersAndSort(rows) {
            const { school, van, sort } = getFilters();
            let result = rows.slice();

            if (school) result = result.filter(r => (r.school_name ?? '') === school);
            if (van)    result = result.filter(r => (r.vehicle_plate ?? '') === van);

            if (sort === 'asc') {
                result.sort((a, b) => timeToMinutes(a.scheduled_end_time) - timeToMinutes(b.scheduled_end_time));
            } else if (sort === 'desc') {
                result.sort((a, b) => timeToMinutes(b.scheduled_end_time) - timeToMinutes(a.scheduled_end_time));
            }

            return result;
        }

        // Populate the school dropdown from loaded data
        function populateSchoolDropdown() {
            const select = document.getElementById('filter-school');
            const allRows = [..._manifestData.morning, ..._manifestData.afternoon];
            const schools = [...new Set(allRows.map(r => r.school_name).filter(Boolean))].sort();
            // Preserve current selection
            const current = select.value;
            select.innerHTML = '<option value="">All Schools</option>';
            schools.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s;
                opt.textContent = s;
                if (s === current) opt.selected = true;
                select.appendChild(opt);
            });
        }

        // ==========================================
        // Render a manifest section (with filter/sort applied)
        // ==========================================
        function renderSection(containerId, countId, rows, tripType) {
            const container = document.getElementById(containerId);
            const countBadge = document.getElementById(countId);
            const filtered = applyFiltersAndSort(rows);

            if (!filtered.length) {
                const isEmpty = !rows.length;
                container.innerHTML = `<div class="text-gray-400 text-sm italic">${isEmpty ? 'No students on this manifest.' : 'No students match the current filters.'}</div>`;
                countBadge.textContent = rows.length ? `0 / ${rows.length} shown` : '';
                return;
            }
            const present = filtered.filter(r => !r.is_absent).length;
            countBadge.textContent = `${present} / ${filtered.length} present`;
            container.innerHTML = filtered.map(r => renderRow(r, tripType)).join('');
        }

        function rerender() {
            renderSection('morning-manifest',   'morning-count',   _manifestData.morning,   'morning');
            renderSection('afternoon-manifest', 'afternoon-count', _manifestData.afternoon, 'afternoon');
        }

        // ==========================================
        // API calls
        // ==========================================
        async function apiFetch(path, options = {}) {
            const res = await fetch(`${API_BASE}/api/manifest${path}`, {
                headers: { 'Content-Type': 'application/json' },
                ...options,
            });
            if (!res.ok) {
                const err = await res.json().catch(() => ({}));
                throw new Error(err.error ?? `HTTP ${res.status}`);
            }
            return res.json();
        }

        async function loadManifest(date) {
            const [morning, afternoon] = await Promise.all([
                apiFetch(`?date=${date}&trip_type=morning&tenant_id=${TENANT_ID}`),
                apiFetch(`?date=${date}&trip_type=afternoon&tenant_id=${TENANT_ID}`),
            ]);
            return { morning, afternoon };
        }

        async function generateManifest(date) {
            const [morning, afternoon] = await Promise.all([
                apiFetch('/generate', {
                    method: 'POST',
                    body: JSON.stringify({ date, trip_type: 'morning', tenant_id: TENANT_ID }),
                }),
                apiFetch('/generate', {
                    method: 'POST',
                    body: JSON.stringify({ date, trip_type: 'afternoon', tenant_id: TENANT_ID }),
                }),
            ]);
            return { morning, afternoon };
        }

        // Feature 6: fetch transfers for both trip types and populate _transferData
        async function loadTransfers(date) {
            try {
                const [morning, afternoon] = await Promise.all([
                    apiFetch(`/transfers?date=${date}&trip_type=morning&tenant_id=${TENANT_ID}`),
                    apiFetch(`/transfers?date=${date}&trip_type=afternoon&tenant_id=${TENANT_ID}`),
                ]);
                _transferData.morning   = new Map((morning   ?? []).map(t => [t.student_id, t]));
                _transferData.afternoon = new Map((afternoon ?? []).map(t => [t.student_id, t]));
            } catch (_) {
                // Transfers are non-critical; silently ignore if endpoint not yet live
                _transferData = { morning: new Map(), afternoon: new Map() };
            }
        }

        // ==========================================
        // Store data + render
        // ==========================================
        function storeAndRender(morning, afternoon) {
            _manifestData.morning   = morning   ?? [];
            _manifestData.afternoon = afternoon ?? [];
            populateSchoolDropdown();
            rerender();
        }

        // ==========================================
        // Absence modal state
        // ==========================================
        let _pendingAbsenceId   = null;
        let _pendingAbsenceBtn  = null;

        window.openAbsenceModal = function(rowId, studentName, btn) {
            _pendingAbsenceId  = rowId;
            _pendingAbsenceBtn = btn;
            document.getElementById('modal-student-name').textContent = studentName;
            document.getElementById('absence-reason').value = '';
            document.getElementById('absence-modal').classList.remove('hidden');
        };

        document.getElementById('modal-cancel').addEventListener('click', () => {
            document.getElementById('absence-modal').classList.add('hidden');
        });

        document.getElementById('modal-confirm').addEventListener('click', async () => {
            const reason = document.getElementById('absence-reason').value.trim();
            document.getElementById('absence-modal').classList.add('hidden');
            if (!_pendingAbsenceId) return;

            try {
                await apiFetch(`/${_pendingAbsenceId}/absent`, {
                    method: 'PATCH',
                    body: JSON.stringify({ reason }),
                });
                // Update cached data
                for (const type of ['morning', 'afternoon']) {
                    const r = _manifestData[type].find(r => r.id == _pendingAbsenceId);
                    if (r) { r.is_absent = true; r.absence_reason = reason; }
                }
                // Update row in-place
                const row = document.getElementById(`row-${_pendingAbsenceId}`);
                if (row) {
                    row.classList.remove('bg-white', 'border-gray-200');
                    row.classList.add('bg-red-50', 'border-red-200');
                    const badge = row.querySelector('span[class*="rounded-full"]:not([class*="purple"])');
                    if (badge) badge.outerHTML = `<span class="inline-block bg-red-100 text-red-700 text-xs font-bold px-2 py-0.5 rounded-full">Absent</span>`;
                    const btn = row.querySelector('button:last-of-type');
                    if (btn) {
                        btn.textContent = '✓ Mark Present';
                        btn.className = 'text-xs bg-green-100 hover:bg-green-200 text-green-700 font-bold px-3 py-1 rounded-lg transition';
                        btn.setAttribute('onclick', `markPresent(${_pendingAbsenceId}, this)`);
                    }
                    if (reason) {
                        const notesArea = row.querySelector('.flex-1');
                        if (notesArea) {
                            const reasonDiv = document.createElement('div');
                            reasonDiv.className = 'text-xs text-red-500 mt-0.5';
                            reasonDiv.textContent = `Reason: ${reason}`;
                            notesArea.appendChild(reasonDiv);
                        }
                    }
                }
                updateCounts();
            } catch (err) {
                alert('Failed to mark absent: ' + err.message);
            }
        });

        window.markPresent = async function(rowId, btn) {
            try {
                await apiFetch(`/${rowId}/present`, { method: 'PATCH' });
                // Update cached data
                for (const type of ['morning', 'afternoon']) {
                    const r = _manifestData[type].find(r => r.id == rowId);
                    if (r) { r.is_absent = false; r.absence_reason = null; }
                }
                const row = document.getElementById(`row-${rowId}`);
                if (row) {
                    row.classList.remove('bg-red-50', 'border-red-200');
                    row.classList.add('bg-white', 'border-gray-200');
                    const badge = row.querySelector('span[class*="rounded-full"]:not([class*="purple"])');
                    if (badge) badge.outerHTML = `<span class="inline-block bg-gray-100 text-gray-600 text-xs font-bold px-2 py-0.5 rounded-full">Scheduled</span>`;
                    btn.textContent = '✕ Mark Absent';
                    btn.className = 'text-xs bg-red-100 hover:bg-red-200 text-red-700 font-bold px-3 py-1 rounded-lg transition';
                    const nameEl = row.querySelector('.font-bold.text-gray-900');
                    const name = nameEl ? nameEl.textContent : '';
                    btn.setAttribute('onclick', `openAbsenceModal(${rowId}, '${name.replace(/'/g, "\\'")}', this)`);
                    const reasonEl = row.querySelector('.text-red-500.text-xs');
                    if (reasonEl) reasonEl.remove();
                }
                updateCounts();
            } catch (err) {
                alert('Failed to mark present: ' + err.message);
            }
        };

        function updateCounts() {
            ['morning', 'afternoon'].forEach(type => {
                const container = document.getElementById(`${type}-manifest`);
                const countBadge = document.getElementById(`${type}-count`);
                if (!container || !countBadge) return;
                const rows = container.querySelectorAll('[id^="row-"]');
                const absent = container.querySelectorAll('.bg-red-50').length;
                const total = rows.length;
                countBadge.textContent = `${total - absent} / ${total} present`;
            });
        }

        // ==========================================
        // Status helper
        // ==========================================
        function setStatus(msg, type = 'info') {
            const el = document.getElementById('manifest-status');
            const colours = { info: 'text-gray-400', ok: 'text-green-600', error: 'text-red-500', loading: 'text-yellow-500' };
            el.className = `text-sm ml-auto self-center ${colours[type] ?? 'text-gray-400'}`;
            el.textContent = msg;
        }

        // ==========================================
        // Filter bar wiring
        // ==========================================
        document.getElementById('btn-apply-filters').addEventListener('click', rerender);

        document.getElementById('btn-clear-filters').addEventListener('click', () => {
            document.getElementById('filter-school').value = '';
            document.getElementById('filter-van').value    = '';
            document.getElementById('sort-time').value     = '';
            rerender();
        });

        // ==========================================
        // Wire up generate / load buttons
        // ==========================================
        document.getElementById('manifest-date').value = today();

        document.getElementById('btn-generate').addEventListener('click', async () => {
            const date = document.getElementById('manifest-date').value;
            if (!date) return alert('Please select a date.');
            setStatus('⚡ Generating…', 'loading');
            try {
                await generateManifest(date);
                const [data] = await Promise.all([
                    loadManifest(date),
                    loadTransfers(date),
                ]);
                storeAndRender(data.morning, data.afternoon);
                setStatus(`✓ Generated for ${date}`, 'ok');
            } catch (err) {
                setStatus('✗ ' + err.message, 'error');
            }
        });

        document.getElementById('btn-load').addEventListener('click', async () => {
            const date = document.getElementById('manifest-date').value;
            if (!date) return alert('Please select a date.');
            setStatus('Loading…', 'loading');
            try {
                const [data] = await Promise.all([
                    loadManifest(date),
                    loadTransfers(date),
                ]);
                storeAndRender(data.morning, data.afternoon);
                setStatus(`✓ Loaded for ${date}`, 'ok');
            } catch (err) {
                setStatus('✗ ' + err.message, 'error');
            }
        });

        // Auto-load today on page open
        (async () => {
            setStatus('Loading today…', 'loading');
            try {
                const date = today();
                const [data] = await Promise.all([
                    loadManifest(date),
                    loadTransfers(date),
                ]);
                storeAndRender(data.morning, data.afternoon);
                setStatus(`✓ Loaded for today`, 'ok');
            } catch (err) {
                setStatus('', 'info');
            }
        })();
    </script>
</Layout>