---
// src/layouts/Layout.astro
const { title } = Astro.props;
import '../styles/global.css';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Midah School Bus</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans flex flex-col min-h-screen">
    
    <nav class="bg-yellow-400 p-3 sm:p-4 shadow-md sticky top-0 z-50">
      <div class="container mx-auto flex justify-between items-center">
        
        <a href="/" class="flex items-center gap-1.5 sm:gap-2 group">
          <span class="text-xl sm:text-2xl">🚌</span>
          
          <span class="font-bold text-sm sm:text-xl text-black leading-tight">
            Midah School Bus
          </span>
        </a>

        <div class="flex items-center gap-2 sm:gap-4">
          <a href="/routes" class="text-sm sm:text-base font-medium hover:underline text-gray-900">
            Routes
          </a>
          <a href="/register" class="bg-black text-white px-3 py-1.5 sm:px-4 sm:py-2 rounded-lg text-xs sm:text-sm font-bold shadow hover:bg-gray-800 transition whitespace-nowrap">
            Register
          </a>
        </div>

      </div>
    </nav>

    <main class="container mx-auto p-4 flex-grow">
      <slot /> 
    </main>

    <footer class="bg-gray-900 text-gray-400 p-8 text-center mt-auto text-sm">
      <p>&copy; 2026 Midah Transport Services.</p>
      <p class="mt-2 text-gray-500">Coverage: Cheras • Bandar Tun Razak • Permaisuri</p>
    </footer>

  </body>
</html>